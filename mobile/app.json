{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "This app needs your location to set rental location when adding items and to filter by distance.",
          "locationAlwaysAndWhenInUsePermission": "This app needs your location to set rental location when adding items and to filter by distance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photos to add images to items."
        }
      ],
      [
        "react-native-auth0",
        {
          "domain": "YOUR_TENANT_REGION.auth0.com",
          "customScheme": "rentals"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bohachicks.rentals"
    },
    "android": {
      "package": "com.bohachicks.rentals",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "MGAB Rentals"
    }
  }
}
